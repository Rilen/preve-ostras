# ──────────────────────────────────────────────────────────────
# Variáveis de Ambiente – Preve-Ostras  (TEMPLATE SEGURO)
#
# Copie este arquivo para .env e preencha com os valores reais.
# Encontre os valores em: Console Firebase → Configurações do Projeto
#
# O arquivo .env NÃO deve ser commitado (está no .gitignore).
# Este .env.example SIM pode ser commitado — não tem valores reais.
# ──────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:aaaaaaaaaaaaaaaa
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
